{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Simple Chat",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "main.go",
      "args": [
        "-c",
        "${input:configfile}",
        "chat",
        "What is the capital of France?"
      ]
    },
    {
      "name": "Launch cli",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${fileDirname}",
      "args": [
        "${input:command}",
        "--file",
        "${input:file}"
      ],
    }
  ],
  "inputs": [
    {
      "id": "command",
      "type": "promptString",
      "description": "Please enter the CLI command",
      "default": ""
    },
    {
      "id": "file",
      "type": "promptString",
      "description": "Please enter the file",
      "default": ""
    },
    {
      "id": "configfile",
      "type": "promptString",
      "description": "Please enter the path to the config file",
      "default": ""
    }
  ]
}