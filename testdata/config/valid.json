{
  "name": "Test Config",
  "version": "1.0.0",
  "settings": {
    "debug": false,
    "verbose": true
  },
  "openai": {
    "base_url": "https://api.openai.com/v1",
    "api_key": "sk-test-key",
    "http_client": {
      "timeout": 120,
      "max_retries": 3,
      "retry_delay": 1000
    },
    "defaults": {
      "model": "gpt-4",
      "temperature": 0.7,
      "max_tokens": 2048,
      "top_p": 1.0
    }
  },
  "execution": {
    "engine": "",
    "timeout": "30s"
  },
  "agent": {
    "system": "You are a helpful coding assistant. Use <do>...</do> tags to wrap bash commands you want to execute.",
    "max_turns": 5
  }
}